#include <iostream>
#include <random> 
#include <time.h> 
using namespace std;

double numberPi(int n){
    
    struct timespec start, end; 
    clock_gettime (CLOCK_MONOTONIC_RAW, &start);
    
    int m = 0; 
    double x; 
    double y;
    
    random_device rd;
    uniform_real_distribution<double> dist(-1.0,1.0);
    
    for (int i = 0; i < n; i++){
        x = dist(rd);
        y = dist(rd);

        if (x*x+y*y<=1){
            m+=1;
        }
    
    double p = 4.0*m/n;
    cout << "Number Pi: " << p << endl;
    
    clock_gettime (CLOCK_MONOTONIC_RAW, &end) ; 
    cout << "Time taken:"<< end.tv_sec-start.tv_sec 
    + 0.000000001*(end. tv_nsec-start.tv_nsec) << "sec." << endl; 
    
    return 0;
}

int main(int argc, char* argv[]){

    if(argc!=2){
        cerr << "Error! Pattern: ./program N" << endl; return 1;
    }

    int n = atoi(argv[1]);

    if (n<=0){
        cerr << "N must be > 0 !" << endl;
    }

    cout << "\033[32m" << "----- 0.5*N ----- " << "\033 [0m" << endl;
    numberPi(0.5*n);

    cout << "\033[32m" << "-------N -----" << "\033[0m" << endl;
    numberPi(n);

    cout << "\033[32m" << "---- 1.5*N —---" << "\033[0m" << endl;
    numberPi(1.5*n);

    return 0;
}
